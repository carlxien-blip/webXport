{
  "manifest_version": 3,
  "name": "webXport",
  "version": "0.1.0",
  "description": "在已登录的浏览器里录制操作，定时重放下载数据报表",
  "permissions": [
    "storage",
    "alarms",
    "downloads",
    "scripting",
    "tabs"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/index.ts"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "webXport"
  }
}
